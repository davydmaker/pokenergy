rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    match /rooms/{roomId} {
      // Allow fetching a room by code, but not listing all rooms
      allow get: if request.auth != null;
      allow list: if false;

      // Create room: hostId = uid, status = waiting, name < 50 chars
      allow create: if request.auth != null
                    && request.resource.data.hostId == request.auth.uid
                    && request.resource.data.status == 'waiting'
                    && request.resource.data.keys().hasAll(['id', 'hostId', 'status', 'currentTurn', 'turnOrder', 'players', 'createdAt'])
                    && request.resource.data.players[request.auth.uid].name.size() < 50;

      // Update: role-based rules (host vs player vs new player)
      allow update: if request.auth != null
                    && request.resource.data.hostId == resource.data.hostId
                    && request.resource.data.id == resource.data.id
                    && (
                      // New player joining (room in waiting status)
                      (
                        resource.data.status == 'waiting'
                        && !(request.auth.uid in resource.data.players)
                        && request.auth.uid in request.resource.data.players
                        && request.resource.data.players[request.auth.uid].name.size() < 50
                        && request.resource.data.status == resource.data.status
                        && request.resource.data.currentTurn == resource.data.currentTurn
                      )
                      // Host can change status (valid transitions only)
                      || (
                        request.auth.uid == resource.data.hostId
                        && request.auth.uid in resource.data.players
                        && (
                          (resource.data.status == 'waiting' && request.resource.data.status == 'configuring')
                          || (resource.data.status == 'configuring' && request.resource.data.status == 'playing')
                          || request.resource.data.status == resource.data.status
                        )
                      )
                      // Existing player can only update their own data
                      || (
                        request.auth.uid in resource.data.players
                        && request.resource.data.status == resource.data.status
                        && request.resource.data.turnOrder == resource.data.turnOrder
                      )
                    );

      // Only the host can delete
      allow delete: if request.auth != null
                    && resource.data.hostId == request.auth.uid;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
