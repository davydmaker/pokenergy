# Firebase is OPTIONAL and only needed for multiplayer.
# Leave these blank to run in sandbox mode: solo play works, multiplayer is disabled.
# Fill them in with your Firebase web app credentials to enable multiplayer.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
